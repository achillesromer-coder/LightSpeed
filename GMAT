      .gmat-dot.cyan{background:#00d4ff;box-shadow:0 0 6px #00d4ff}
      .gmat-dot.amber{background:#ffaa00;box-shadow:0 0 6px #ffaa00}
      @keyframes gmatPulse{0%,100%{opacity:1}50%{opacity:.4}}
      .gmat-body{padding:24px 32px;display:grid;grid-template-columns:280px 1fr;gap:24px;min-height:760px}
      .gmat-sidebar{display:flex;flex-direction:column;gap:12px}
      .gmat-section{background:rgba(0,212,255,.03);border:1px solid #0a2040;border-radius:8px;padding:16px}
      .gmat-section-title{font-size:10px;font-weight:700;color:#00d4ff;letter-spacing:2px;margin-bottom:12px;text-transform:uppercase}
      .gmat-field{margin-bottom:10px}
      .gmat-label{font-size:10px;color:#557;margin-bottom:3px;letter-spacing:.5px;display:block}
      .gmat-input{width:100%;background:rgba(0,212,255,.05);border:1px solid #0d2040;border-radius:4px;color:#cde;padding:7px 10px;font-size:12px;outline:none;transition:.2s;font-family:inherit}
      .gmat-input:focus{border-color:#00d4ff;background:rgba(0,212,255,.08)}
      .gmat-input.gmat-err{border-color:#ff4455!important;background:rgba(255,68,85,.08)!important}
      .gmat-select{width:100%;background:#020c1a;border:1px solid #0d2040;border-radius:4px;color:#cde;padding:7px 10px;font-size:12px;outline:none;cursor:pointer;font-family:inherit}
      .gmat-btn{width:100%;padding:9px;border-radius:4px;border:none;cursor:pointer;font-size:11px;font-weight:700;letter-spacing:1.5px;transition:.3s;margin-bottom:6px;text-transform:uppercase;font-family:inherit}
      .gmat-btn-primary{background:linear-gradient(135deg,#00d4ff,#0099cc);color:#000}
      .gmat-btn-primary:hover{background:linear-gradient(135deg,#00eeff,#00b8e6);transform:translateY(-1px)}
      .gmat-btn-secondary{background:rgba(0,212,255,.08);color:#00d4ff;border:1px solid rgba(0,212,255,.3)}
      .gmat-btn-secondary:hover{background:rgba(0,212,255,.16)}
      .gmat-btn-warning{background:rgba(255,170,0,.1);color:#ffaa00;border:1px solid rgba(255,170,0,.3)}
      .gmat-btn-warning:hover{background:rgba(255,170,0,.2)}
      .gmat-btn-danger{background:rgba(255,100,50,.1);color:#ff6432;border:1px solid rgba(255,100,50,.3)}
      .gmat-btn-danger:hover{background:rgba(255,100,50,.2)}
