  function loadParams() {
    try {
      var p = JSON.parse(localStorage.getItem(PARAM_KEY) || "null");
      if (!p) return;
      Object.keys(p).forEach(function (k) {
        var el = $(k);
        if (!el) return;
        if (el.type === "checkbox") el.checked = !!p[k];
        else el.value = p[k];
      });
    } catch (e) {}
  }

