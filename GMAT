      "",
      "Create ChemicalTank " + prop.tank + ";",
      "GMAT " + prop.tank + ".FuelMass = " + p.g_fuel + ";",
      "",
      "Create Thruster " + prop.thr + ";",
      "GMAT " + prop.thr + ".ThrustDirection1 = 1;",
      "GMAT " + prop.thr + ".ThrustDirection2 = 0;",
      "GMAT " + prop.thr + ".ThrustDirection3 = 0;",
      "GMAT " + prop.thr + ".Isp = " + p.g_isp + ";",
      "GMAT " + prop.thr + ".ThrustScaleFactor = " + p.g_thrust + ";",
      "",
      "Create ForceModel MainFM;",
      forceModelLines(),
      "",
      "Create Propagator MainProp;",
      "GMAT MainProp.Type = " + p.g_integ + ";",
      "GMAT MainProp.InitialStepSize = " + p.g_step + ";",
      "GMAT MainProp.MaxStep = " + p.g_maxstep + ";",
      "GMAT MainProp.FM = MainFM;",
      "",
      "Create ReportFile MissionReport;",
      "GMAT MissionReport.Filename = '" + p.g_name + "_report.txt';",
      "",
      "% B-Plane placeholders",
      "% BdotT = " + p.g_bdott,
      "% BdotR = " + p.g_bdotr,
      "% Attitude = " + p.g_att,
      "",
      "BeginMissionSequence;",
      "Propagate MainProp(AchillesSC) {AchillesSC.ElapsedDays = " + Math.max(1, result.tofDays).toFixed(3) + "};",
      "Report MissionReport AchillesSC.ElapsedDays AchillesSC.SMA AchillesSC.ECC AchillesSC.INC;",
      "",
      "% Derived mission estimates",
      "% Transfer Class: " + result.body.transfer,
      "% Est Total DV: " + result.dv.toFixed(3) + " m/s",
      "% Est TOF: " + result.tofDays.toFixed(3) + " days",
      "% Est Final Mass: " + result.finalMass.toFixed(3) + " kg",
      "% Est C3: " + result.c3.toFixed(3) + " km^2/s^2",
      "",
      "% End of script"
    ].join("\n");

    $("g_output").textContent = out;
    $("g_status").textContent = "SCRIPT GENERATED";
    $("g_prog").style.width = "100%";

    pushHistory({
      mission: p.g_name,
      target: p.g_target,
      type: p.g_type,
      epoch: p.g_epoch,
      script: out,
      params: p,
      summary: {
        dv: result.dv.toFixed(0),
        tof: result.tofDays.toFixed(0),
        mf: result.finalMass.toFixed(0),
        c3: result.c3.toFixed(2)
      },
      ts: Date.now()
    });

    showToast("GMAT script generated", "ok");
  }

  function copyScript() {
    var text = $("g_output").textContent;
    navigator.clipboard.writeText(text).then(function () {
      showToast("Script copied to clipboard", "ok");
    }).catch(function () {
      showToast("Clipboard copy failed", "err");
    });
  }

  function exportScript() {
    var name = getValue("g_name").trim() || "mission";
    var blob = new Blob([$(
      "g_output"
    ).textContent], { type: "text/plain" });
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = name + ".script";
    a.click();
    URL.revokeObjectURL(a.href);
    showToast("Script exported", "ok");
  }

  function shareURL() {
    var params = readParams();
    var enc = encodeURIComponent(btoa(JSON.stringify(params)));
    var url = location.origin + location.pathname + "#gmat=" + enc;
    navigator.clipboard.writeText(url).then(function () {
      showToast("Mission URL copied to clipboard", "ok");
    }).catch(function () {
      showToast("Share URL generated — copy manually", "");
      prompt("Copy mission URL:", url);
    });
  }

  function sendToData() {
    var result = computeMission();
    if (!result) return;
    var payload = {
      mission: getValue("g_name"),
      target: getValue("g_target"),
      epoch: getValue("g_epoch"),
      type: getValue("g_type"),
      propulsion: getValue("g_prop"),
      dv_mps: +result.dv.toFixed(3),
      tof_days: +result.tofDays.toFixed(3),
      final_mass_kg: +result.finalMass.toFixed(3),
      c3_km2_s2: +result.c3.toFixed(3),
      generated_utc: new Date().toISOString()
    };
    localStorage.setItem("ach_gmat_to_w1_data", JSON.stringify(payload));
    showToast("Mission payload staged for W1/DATA", "ok");
  }

  function applyURLState() {
    try {
      if (!location.hash || location.hash.indexOf("#gmat=") !== 0) return;
      var raw = location.hash.replace("#gmat=", "");
      var p = JSON.parse(atob(decodeURIComponent(raw)));
      Object.keys(p).forEach(function (k) {
        var el = $(k);
        if (!el) return;
        if (el.type === "checkbox") el.checked = !!p[k];
        else el.value = p[k];
      });
      showToast("Mission loaded from shared URL", "ok");
    } catch (e) {
      showToast("Failed to parse shared mission URL", "err");
    }
  }

  function computeOnly() {
    var r = computeMission();
    if (!r) return;
    $("g_status").textContent = "MISSION ANALYSIS COMPUTED";
    $("g_prog").style.width = "68%";
    showToast("Mission analysis computed", "ok");
  }

  function pushHistory(item) {
    var h = JSON.parse(localStorage.getItem(STORE_KEY) || "[]");
    h.unshift(item);
    h = h.slice(0, 10);
    localStorage.setItem(STORE_KEY, JSON.stringify(h));
    renderHistory();
  }

  function renderHistory() {
    var el = $("history_list");
    var h = JSON.parse(localStorage.getItem(STORE_KEY) || "[]");
    if (!h.length) {
      el.innerHTML = '<div class="gmat-history-empty">NO SAVED MISSIONS</div>';
      return;
    }
    el.innerHTML = h.map(function (x, i) {
      return `
        <div class="gmat-history-item">
          <div>
            <div class="gmat-history-name">${escapeHtml(x.mission)}</div>
            <div class="gmat-history-meta">${escapeHtml(x.target)} · ${escapeHtml(x.type)} · ${new Date(x.ts).toLocaleString()}</div>
          </div>
          <div class="gmat-history-btns">
            <button class="gmat-hbtn gmat-hbtn-restore" data-restore="${i}">RESTORE</button>
            <button class="gmat-hbtn gmat-hbtn-del" data-del="${i}">DELETE</button>
          </div>
        </div>
      `;
    }).join("");

    Array.prototype.forEach.call(el.querySelectorAll("[data-restore]"), function (b) {
      b.onclick = function () {
        var idx = +b.getAttribute("data-restore");
        var arr = JSON.parse(localStorage.getItem(STORE_KEY) || "[]");
        var item = arr[idx];
        if (!item) return;
        Object.keys(item.params).forEach(function (k) {
          var node = $(k);
          if (!node) return;
          if (node.type === "checkbox") node.checked = !!item.params[k];
          else node.value = item.params[k];
        });
        $("g_output").textContent = item.script;
        computeOnly();
        showToast("Mission restored from history", "ok");
      };
    });

    Array.prototype.forEach.call(el.querySelectorAll("[data-del]"), function (b) {
      b.onclick = function () {
        var idx = +b.getAttribute("data-del");
        var arr = JSON.parse(localStorage.getItem(STORE_KEY) || "[]");
        arr.splice(idx, 1);
        localStorage.setItem(STORE_KEY, JSON.stringify(arr));
        renderHistory();
        showToast("Mission deleted from history", "");
      };
    });
  }

  function renderSamples(filter) {
    var el = $("samples_grid");
    var list = SAMPLE_SCRIPTS.filter(function (x) {
      return filter === "all" ? true : x.cat === filter;
    });
    el.innerHTML = list.map(function (x) {
      return `
        <a class="gmat-sample-item" href="${x.url}" target="_blank" rel="noopener">
          <div class="gmat-sample-name">${escapeHtml(x.name)}</div>
          <div class="gmat-sample-cat">${escapeHtml(x.cat)}</div>
        </a>
      `;
    }).join("");
  }

  function renderTemplates() {
    $("tpl_grid").innerHTML = TEMPLATE_SET.map(function (t, i) {
      return `
        <div class="gmat-tpl" data-tpl="${i}">
          <div class="gmat-tpl-name">${escapeHtml(t.name)}</div>
          <div class="gmat-tpl-desc">${escapeHtml(t.desc)}</div>
        </div>
      `;
    }).join("");

    Array.prototype.forEach.call($("tpl_grid").querySelectorAll("[data-tpl]"), function (card) {
      card.onclick = function () {
        var idx = +card.getAttribute("data-tpl");
        TEMPLATE_SET[idx].apply();
        saveParams();
        showToast("Template applied: " + TEMPLATE_SET[idx].name, "ok");
      };
    });
  }

  function tab(name, btn) {
    Array.prototype.forEach.call(root.querySelectorAll(".gmat-tab"), function (b) {
      b.classList.toggle("active", b === btn);
    });
    Array.prototype.forEach.call(root.querySelectorAll(".gmat-panel"), function (p) {
      p.classList.remove("active");
    });
    $("panel_" + name).classList.add("active");
  }

  function tickUTC() {
    var d = new Date();
    var t = d.toUTCString().replace("GMT", "UTC");
    $("g_utc").textContent = t;
  }

  function escapeHtml(s) {
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  Array.prototype.forEach.call(root.querySelectorAll(".gmat-tab"), function (b) {
    b.onclick = function () { tab(b.getAttribute("data-tab"), b); };
  });

  Array.prototype.forEach.call(root.querySelectorAll(".gmat-filter-btn"), function (b) {
    b.onclick = function () {
      Array.prototype.forEach.call(root.querySelectorAll(".gmat-filter-btn"), function (x) { x.classList.remove("active"); });
      b.classList.add("active");
      renderSamples(b.getAttribute("data-filter"));
    };
  });

  Array.prototype.forEach.call(root.querySelectorAll(".gmat-input, .gmat-select, .gmat-checkbox"), function (el) {
    el.addEventListener("change", saveParams);
    el.addEventListener("input", saveParams);
  });

  $("btn_generate").onclick = generateScript;
  $("btn_compute").onclick = computeOnly;
  $("btn_copy").onclick = copyScript;
  $("btn_export").onclick = exportScript;
  $("btn_print").onclick = function () { window.print(); };
  $("btn_share").onclick = shareURL;
  $("btn_send").onclick = sendToData;

  loadParams();
  applyURLState();
  renderSamples("all");
  renderTemplates();
  renderHistory();
  tickUTC();
  setInterval(tickUTC, 1000);
  computeOnly();

  window.GMAT2 = {
    generate: generateScript,
    compute: computeOnly,
    copy: copyScript,
    exportScript: exportScript,
    shareURL: shareURL,
    sendToData: sendToData,
    tab: function (name, btn) { tab(name, btn); },
    filterSamples: function (filter, btn) {
      Array.prototype.forEach.call(root.querySelectorAll(".gmat-filter-btn"), function (x) { x.classList.remove("active"); });
      if (btn) btn.classList.add("active");
      renderSamples(filter);
    }
  };
})();
</script>
