  function validate() {
    var ids = ["g_name","g_epoch","g_mass","g_isp","g_thrust","g_fuel","g_sma","g_ecc","g_inc","g_step","g_maxstep"];
    var ok = true;
    ids.forEach(function (id) {
      var el = $(id);
      el.classList.remove("gmat-err");
      if (!el.value.trim()) { el.classList.add("gmat-err"); ok = false; }
    });
    if (getNum("g_mass") <= 0 || getNum("g_fuel") <= 0 || getNum("g_isp") <= 0 || getNum("g_sma") <= 0) ok = false;
    if (getNum("g_ecc") < 0 || getNum("g_ecc") >= 1) ok = false;
    if (!ok) showToast("Validation failed — check highlighted / invalid fields", "err");
    return ok;
  }

  function julianLikeWindowDays(target) {
    var body = TARGET_DB[target] || TARGET_DB.Custom;
    if (target === "Mars") return 780;
    if (target === "Moon") return 27.3;
    if (target === "L2") return 14.0;
    if (target === "Jupiter") return 399;
    if (target === "433Eros") return 120;
    if (target === "16Psyche" || target === "1Ceres") return 420;
    return Math.max(30, body.aAU * 150);
  }

  function computeMission() {
    if (!validate()) return null;

    var target = getValue("g_target");
    var body = TARGET_DB[target] || TARGET_DB.Custom;

    var wet = getNum("g_mass");
    var fuel = getNum("g_fuel");
    var isp = getNum("g_isp");
    var thrust = getNum("g_thrust");
    var dry = Math.max(1, wet - fuel);
    var g0 = 9.80665;

    var dv = isp * g0 * Math.log(wet / dry);
    var finalMass = dry;

    var originAU = 1.0;
    var destAU = body.aAU;
    var muSun = 1.32712440018e11; // km^3/s^2
    var AUkm = 149597870.7;
    var r1 = originAU * AUkm;
    var r2 = destAU * AUkm;
    var aTrans = (r1 + r2) / 2;
    var tofDays = Math.PI * Math.sqrt((aTrans * aTrans * aTrans) / muSun) / 86400;
    if (target === "Moon") tofDays = 5;
    if (target === "L2") tofDays = 21;

    var c3 = Math.max(0, Math.abs(destAU - originAU) * 12 + (thrust < 1 ? 1.2 : 3.6));
    var nextWindow = julianLikeWindowDays(target);

    var dep = dv * 0.42;
    var cruise = dv * 0.08;
    var app = dv * 0.18;
    var ops = dv * 0.07;
    var ret = (getValue("g_type") === "return") ? dv * 0.25 : dv * 0.05;

    setText("g_dv", dv.toFixed(0));
    setText("g_tof", tofDays.toFixed(0));
    setText("g_mfinal", finalMass.toFixed(0));
    setText("g_c3", c3.toFixed(2));

    setText("ph0_dv", dep.toFixed(0) + " m/s");
    setText("ph1_dv", cruise.toFixed(0) + " m/s");
    setText("ph2_dv", app.toFixed(0) + " m/s");
    setText("ph3_dv", ops.toFixed(0) + " m/s");
    setText("ph4_dv", ret.toFixed(0) + " m/s");

    ["ph0","ph1","ph2","ph3","ph4"].forEach(function (id, idx) {
      var el = $(id);
      el.classList.remove("active","complete");
      if (idx === 0) el.classList.add("active");
      if (idx < 1) el.classList.add("complete");
    });

    setText("a_window", nextWindow.toFixed(1) + " d");
    setText("a_window_sub", "Next nominal launch opportunity cadence");
    setText("a_transfer", body.transfer);
    setText("a_dvbreak", dep.toFixed(0) + " / " + app.toFixed(0) + " m/s");
    setText("a_propmass", fuel.toFixed(0) + " kg");
    setText("a_c3", c3.toFixed(2) + " km²/s²");

    saveParams();
    return {
      target: target,
      body: body,
      dv: dv,
      tofDays: tofDays,
      finalMass: finalMass,
      c3: c3,
      phases: { dep: dep, cruise: cruise, app: app, ops: ops, ret: ret }
    };
  }

  function forceModelLines() {
    var lines = [];
    if (getCheckbox("g_grav")) lines.push("Create GravityField EarthJGM3;");
    if (getCheckbox("g_drag")) lines.push("Create DragForce AtmDrag;");
    if (getCheckbox("g_srp")) lines.push("Create SolarRadiationPressure SRP;");
    if (getCheckbox("g_nbody")) lines.push("% N-Body point masses: Sun, Luna, major planets");
    if (getCheckbox("g_reldyn")) lines.push("% Relativistic corrections enabled");
    if (getCheckbox("g_emff")) lines.push("% EMFF custom force placeholder enabled");
    return lines.join("\n");
  }

  function propSpec() {
    var prop = getValue("g_prop");
    if (prop === "electric_ion") return { tank: "XenonTank", thr: "IonThruster", mode: "Electric / Ion" };
    if (prop === "electric_hall") return { tank: "XenonTank", thr: "HallThruster", mode: "Electric / Hall" };
    if (prop === "chemical_monoprop") return { tank: "HydrazineTank", thr: "MonoThruster", mode: "Chemical / Monoprop" };
    if (prop === "hybrid") return { tank: "HybridTank", thr: "HybridThruster", mode: "Hybrid" };
    return { tank: "MainTank", thr: "MainThruster", mode: "Chemical / Biprop" };
  }

