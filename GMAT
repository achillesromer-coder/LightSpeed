      .gmat-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
      .gmat-metric{background:rgba(0,212,255,.04);border:1px solid #0a2040;border-radius:8px;padding:14px;text-align:center}
      .gmat-metric-val{font-size:22px;font-weight:700;color:#00d4ff;font-family:monospace;letter-spacing:1px}
      .gmat-metric-unit{font-size:9px;color:#456;margin:2px 0;letter-spacing:1px;text-transform:uppercase}
      .gmat-metric-lbl{font-size:10px;color:#667}
      .gmat-phase-track{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}
      .gmat-phase{background:rgba(0,212,255,.04);border:1px solid #0a2040;border-radius:6px;padding:10px;text-align:center;transition:.3s}
      .gmat-phase.active{border-color:#00d4ff;background:rgba(0,212,255,.1)}
      .gmat-phase.complete{border-color:#00ff88;background:rgba(0,255,136,.05)}
      .gmat-phase-icon{font-size:18px;margin-bottom:4px}
      .gmat-phase-name{font-size:9px;color:#667;letter-spacing:.5px}
      .gmat-phase-dv{font-size:11px;color:#00d4ff;font-family:monospace;margin-top:2px}
      .gmat-tabs{display:flex;border-bottom:1px solid #0a2040;flex-wrap:wrap}
      .gmat-tab{padding:8px 13px;font-size:10px;cursor:pointer;color:#556;border:none;background:none;letter-spacing:1px;text-transform:uppercase;transition:.2s;border-bottom:2px solid transparent;margin-bottom:-1px;font-family:inherit}
      .gmat-tab.active{color:#00d4ff;border-bottom-color:#00d4ff}
      .gmat-panel{display:none;background:rgba(0,0,0,.6);border:1px solid #0a2040;border-top:none;border-radius:0 0 8px 8px;padding:16px}
      .gmat-panel.active{display:block}
      .gmat-terminal{background:#000a1a;border:1px solid #0a2040;border-radius:6px;padding:14px;font-family:'Courier New',monospace;font-size:11px;line-height:1.7;min-height:300px;max-height:540px;overflow-y:auto}
      .gmat-terminal pre{color:#00ff66;white-space:pre-wrap;word-break:break-word}
      .gmat-terminal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:6px}
      .gmat-terminal-title{font-size:10px;color:#00d4ff;letter-spacing:2px}
      .gmat-terminal-status{font-size:9px;color:#456;letter-spacing:1px}
      .gmat-progress{height:3px;background:#0a2040;border-radius:2px;overflow:hidden;margin-top:8px}
      .gmat-progress-bar{height:100%;background:linear-gradient(90deg,#00d4ff,#00ff88);width:0%;transition:width .5s;border-radius:2px}
      .gmat-2col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
      .gmat-3col{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
      .gmat-force-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
      .gmat-force-item{display:flex;align-items:center;gap:8px;font-size:11px;color:#889;padding:6px;border:1px solid #0a2040;border-radius:4px;cursor:pointer}
      .gmat-force-item:hover{border-color:#00d4ff;color:#00d4ff}
      .gmat-checkbox{width:14px;height:14px;accent-color:#00d4ff}
      .gmat-info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
      .gmat-info-card{background:rgba(0,212,255,.03);border:1px solid #0a2040;border-radius:6px;padding:12px}
      .gmat-info-title{font-size:10px;color:#00d4ff;letter-spacing:1px;margin-bottom:6px}
      .gmat-info-val{font-size:13px;font-family:monospace;color:#acd}
      .gmat-info-sub{font-size:9px;color:#556;margin-top:2px}
      .gmat-tpl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
      .gmat-tpl{background:rgba(0,212,255,.04);border:1px solid #0a2040;border-radius:6px;padding:12px;cursor:pointer;transition:.2s}
      .gmat-tpl:hover{border-color:#00d4ff;background:rgba(0,212,255,.1);transform:translateY(-2px)}
      .gmat-tpl-name{font-size:11px;font-weight:700;color:#00d4ff;margin-bottom:4px}
      .gmat-tpl-desc{font-size:9px;color:#556;line-height:1.5}
      .gmat-samples-filter{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}
      .gmat-filter-btn{padding:4px 12px;font-size:9px;border-radius:3px;border:1px solid #0a2040;background:none;color:#556;cursor:pointer;letter-spacing:1px;text-transform:uppercase;font-family:inherit;transition:.2s}
      .gmat-filter-btn.active,.gmat-filter-btn:hover{border-color:#00d4ff;color:#00d4ff;background:rgba(0,212,255,.06)}
      .gmat-samples-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-height:400px;overflow-y:auto}
      .gmat-sample-item{background:rgba(0,212,255,.03);border:1px solid #0a2040;border-radius:5px;padding:10px;cursor:pointer;transition:.2s;text-decoration:none;display:block}
      .gmat-sample-item:hover{border-color:#00d4ff;background:rgba(0,212,255,.08)}
      .gmat-sample-name{font-size:10px;color:#00d4ff;font-weight:700;margin-bottom:3px;word-break:break-word}
      .gmat-sample-cat{font-size:9px;color:#445;letter-spacing:1px;text-transform:uppercase}
      .gmat-history-list{display:flex;flex-direction:column;gap:8px;max-height:420px;overflow-y:auto}
      .gmat-history-item{background:rgba(0,212,255,.03);border:1px solid #0a2040;border-radius:6px;padding:10px 14px;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap}
      .gmat-history-item:hover{border-color:#00d4ff}
      .gmat-history-name{font-size:12px;color:#00d4ff;font-weight:700}
      .gmat-history-meta{font-size:10px;color:#557;font-family:monospace;margin-top:2px}
      .gmat-history-btns{display:flex;gap:6px}
      .gmat-hbtn{padding:4px 10px;font-size:9px;border-radius:3px;border:none;cursor:pointer;letter-spacing:1px;text-transform:uppercase;font-family:inherit}
      .gmat-hbtn-restore{background:rgba(0,212,255,.1);color:#00d4ff;border:1px solid rgba(0,212,255,.3)}
      .gmat-hbtn-del{background:rgba(255,100,50,.1);color:#ff6432;border:1px solid rgba(255,100,50,.3)}
      .gmat-history-empty{font-size:11px;color:#445;text-align:center;padding:40px 0;letter-spacing:1px}
      .gmat-ref-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
      .gmat-ref-card{background:rgba(0,212,255,.03);border:1px solid #0a2040;border-radius:6px;padding:12px}
      .gmat-ref-h{font-size:10px;color:#00d4ff;letter-spacing:1px;margin-bottom:6px;text-transform:uppercase}
      .gmat-ref-body{font-size:10px;color:#89a;line-height:1.7}
      .gmat-toast{position:fixed;bottom:24px;right:24px;background:rgba(0,10,24,.95);border:1px solid rgba(0,212,255,.3);border-radius:6px;padding:10px 18px;font-size:11px;color:#00d4ff;letter-spacing:.5px;z-index:99999;opacity:0;transition:opacity .3s;pointer-events:none;max-width:320px;line-height:1.6;font-family:Inter,system-ui,sans-serif}
      .gmat-toast.show{opacity:1}
      .gmat-toast.err{border-color:rgba(255,68,68,.4);color:#ff6666}
      .gmat-toast.ok{border-color:rgba(0,255,136,.3);color:#00ff88}
      .gmat-license-bar{background:rgba(0,5,20,.97);border-top:1px solid rgba(0,212,255,.12);padding:8px 32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
      .gmat-license-text{font-size:9px;color:#445;letter-spacing:.5px;line-height:1.7}
      .gmat-license-text strong{color:#00d4ff}
      .gmat-utc{font-size:9px;color:#334;font-family:monospace;letter-spacing:1px}
      @media(max-width:800px){
        .gmat-body{grid-template-columns:1fr;padding:14px}
        .gmat-hdr{padding:12px 14px}
        .gmat-status-bar{padding:6px 14px}
        .gmat-metrics{grid-template-columns:repeat(2,1fr)}
        .gmat-phase-track{grid-template-columns:repeat(3,1fr)}
        .gmat-tpl-grid,.gmat-samples-grid,.gmat-info-grid,.gmat-3col,.gmat-ref-grid{grid-template-columns:repeat(2,1fr)}
      }
      @media(max-width:480px){
        .gmat-metrics{grid-template-columns:1fr 1fr}
        .gmat-phase-track{grid-template-columns:repeat(2,1fr)}
        .gmat-tpl-grid,.gmat-samples-grid,.gmat-info-grid,.gmat-ref-grid{grid-template-columns:1fr}
      }
    `;
  }

