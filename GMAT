  function style() {
    return `
      #gmatWrap,#gmatWrap *{margin:0;padding:0;box-sizing:border-box}
      #gmatWrap{font-family:Inter,system-ui,sans-serif;background:linear-gradient(135deg,#020818,#0a1628,#0d1f3c);color:#fff;width:100%;position:relative;border:1px solid #0a2040;border-radius:14px;overflow:hidden}
